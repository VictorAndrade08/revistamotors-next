# Copia este archivo a .env.local y rellena los valores reales.
# .env.local está en .gitignore y NUNCA debe subirse al repositorio.

# Cloudflare D1 — base de datos
CLOUDFLARE_ACCOUNT_ID=tu_account_id
CLOUDFLARE_D1_DATABASE_NAME=motros
CLOUDFLARE_D1_DATABASE_ID=tu_database_id

# Panel de administración (/admin)
ADMIN_USER=admin
ADMIN_PASS=cambia_esta_clave
ADMIN_SECRET=una_cadena_secreta_aleatoria

# Cloudflare R2 — bucket de imágenes
R2_ENDPOINT=https://tu_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key
R2_BUCKET_NAME=medias
